{
  "harnessVersion": "1.0.0",
  "defaultLanguage": "ko",
  "limits": {
    "maxRepairLoops": 3,
    "maxFileSizeLines": 500,
    "maxFileSizeKb": 20,
    "warningContextTokens": 100000
  },
  "roles": [
    "orchestrator",
    "product-strategist",
    "ux-architect",
    "visual-design-director",
    "interaction-designer",
    "frontend-implementer",
    "technical-implementer",
    "design-evaluator",
    "technical-evaluator",
    "bug-reproducer",
    "qa-verifier",
    "documenter",
    "state-manager"
  ],
  "verification": {
    "requireScreenshot": true,
    "requireDesignPassVerdict": true,
    "allowFallbackManualChecklist": true
  },
  "approvalGates": [
    "architecture_change",
    "dependency_addition",
    "auth_modification",
    "database_schema_change",
    "payment_data_handling",
    "destructive_command",
    "bulk_file_movement",
    "deployment",
    "large_refactor"
  ]
}
